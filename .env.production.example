# carestechs-agent-orchestrator — Production environment variables
# Copy to .env on the production host and fill in real values.
# NEVER commit this file with real secrets.

# -- Database ------------------------------------------------------------------
# Standalone (project owns its own postgres):
DATABASE_URL=postgresql+asyncpg://orchestrator:<PASSWORD>@db-host:5432/orchestrator
# Umbrella (shared infra/postgres on the `infra` network):
# DATABASE_URL=postgresql+asyncpg://devtools:devtools@postgres:5432/agent_orchestrator

# -- Auth ----------------------------------------------------------------------
ORCHESTRATOR_API_KEY=<generate-a-strong-random-secret>
ENGINE_WEBHOOK_SECRET=<generate-a-strong-random-secret>

# -- Flow engine ---------------------------------------------------------------
# Standalone:
ENGINE_BASE_URL=https://engine.example.com
# Umbrella (reach flow-engine by container name on the `infra` network):
# ENGINE_BASE_URL=http://flowengine-api:8080
# ENGINE_API_KEY=<engine-bearer-token>

# -- LLM ----------------------------------------------------------------------
LLM_PROVIDER=anthropic
LLM_MODEL=claude-opus-4-6
ANTHROPIC_API_KEY=<your-anthropic-api-key>

# -- Paths ---------------------------------------------------------------------
AGENTS_DIR=/app/agents

# -- Observability -------------------------------------------------------------
LOG_LEVEL=INFO

# -- Postgres (used by docker-compose.prod.yml) --------------------------------
POSTGRES_USER=orchestrator
POSTGRES_PASSWORD=<generate-a-strong-random-password>
POSTGRES_DB=orchestrator
