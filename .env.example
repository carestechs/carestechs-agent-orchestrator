# carestechs-agent-orchestrator — Development environment variables
# Copy to .env and fill in values.

# -- Database ------------------------------------------------------------------
# Standalone (default): the project's own docker-compose.yml brings up postgres
# on localhost.
DATABASE_URL=postgresql+asyncpg://orchestrator:orchestrator@localhost:5432/orchestrator
# DevTools umbrella (~/Desktop/Repos/DevTools/devtools-umbrella.md): use the
# shared cluster's `agent_orchestrator` database under the `postgres` container
# hostname, with the credentials from infra/.env.
# DATABASE_URL=postgresql+asyncpg://devtools:devtools@postgres:5432/agent_orchestrator

# -- Auth ----------------------------------------------------------------------
# Bearer token for the control-plane API (any strong random string).
ORCHESTRATOR_API_KEY=change-me-to-a-random-secret

# HMAC-SHA256 shared secret for engine webhook signatures.
ENGINE_WEBHOOK_SECRET=change-me-to-a-random-secret

# -- Flow engine ---------------------------------------------------------------
# Standalone: flow engine running on the host or via its own compose file.
ENGINE_BASE_URL=http://localhost:9000
# Umbrella: flow engine container on the shared infra network.
# ENGINE_BASE_URL=http://flowengine-api:8080
# ENGINE_API_KEY=           # Optional — set if the engine requires auth.

# -- Flow-engine lifecycle surface (FEAT-006 rc2) ------------------------------
# Points at the same flow engine as ENGINE_BASE_URL, but uses the tenant
# API key + JWT to access the workflows/items/transitions surface. Leave
# unset to run the orchestrator without engine mirroring (local-only mode).
# Standalone:
# FLOW_ENGINE_LIFECYCLE_BASE_URL=http://localhost:9000
# Umbrella:
# FLOW_ENGINE_LIFECYCLE_BASE_URL=http://flowengine-api:8080
# FLOW_ENGINE_TENANT_API_KEY=

# -- LLM ----------------------------------------------------------------------
LLM_PROVIDER=stub           # "stub" (default) or "anthropic"
# LLM_MODEL=                # e.g. claude-opus-4-6 (required when provider != stub)
# ANTHROPIC_API_KEY=        # Required when LLM_PROVIDER=anthropic

# -- Paths ---------------------------------------------------------------------
# AGENTS_DIR=agents         # Directory containing agent YAML definitions.

# -- Lifecycle flow (FEAT-006) -------------------------------------------------
# SOLO_DEV_MODE=true        # false → impl-review requires a dev other than the implementer.
# LIFECYCLE_MAX_CORRECTIONS=2

# -- GitHub integration (FEAT-006 webhook ingress + FEAT-007 merge gating) -----
# HMAC shared secret configured on the GitHub webhook.
# GITHUB_WEBHOOK_SECRET=
# FEAT-007 (not yet wired — placeholders for the upcoming merge-gating client).
# Multi-repo by default: the target owner/repo is parsed per-task from the
# PR URL, so one credential fans out to every repo it has `repo` scope on.
# GITHUB_PAT=               # Classic PAT with `repo` scope. Use PAT OR App, not both.
# GITHUB_APP_ID=
# GITHUB_PRIVATE_KEY=

# -- Observability -------------------------------------------------------------
LOG_LEVEL=INFO              # DEBUG | INFO | WARNING | ERROR
