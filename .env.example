# carestechs-agent-orchestrator — Development environment variables
# Copy to .env and fill in values.

# -- Database ------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://orchestrator:orchestrator@localhost:5432/orchestrator

# -- Auth ----------------------------------------------------------------------
# Bearer token for the control-plane API (any strong random string).
ORCHESTRATOR_API_KEY=change-me-to-a-random-secret

# HMAC-SHA256 shared secret for engine webhook signatures.
ENGINE_WEBHOOK_SECRET=change-me-to-a-random-secret

# -- Flow engine ---------------------------------------------------------------
ENGINE_BASE_URL=http://localhost:9000
# ENGINE_API_KEY=           # Optional — set if the engine requires auth.

# -- LLM ----------------------------------------------------------------------
LLM_PROVIDER=stub           # "stub" (default) or "anthropic"
# LLM_MODEL=                # e.g. claude-opus-4-6 (required when provider != stub)
# ANTHROPIC_API_KEY=        # Required when LLM_PROVIDER=anthropic

# -- Paths ---------------------------------------------------------------------
# AGENTS_DIR=agents         # Directory containing agent YAML definitions.

# -- Observability -------------------------------------------------------------
LOG_LEVEL=INFO              # DEBUG | INFO | WARNING | ERROR
